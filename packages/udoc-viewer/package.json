{
    "name": "@docmentis/udoc-viewer",
    "version": "0.6.10",
    "type": "module",
    "license": "MIT",
    "description": "Universal document viewer for the web — open-source, framework-agnostic viewer powered by a built-from-scratch WebAssembly engine for high-fidelity rendering across PDF, DOCX, PPTX, SVG, and images.",
    "homepage": "https://www.docmentis.com",
    "repository": {
        "type": "git",
        "url": "https://github.com/docMentis/docmentis-udoc-viewer.git",
        "directory": "packages/udoc-viewer"
    },
    "bugs": {
        "url": "https://github.com/docMentis/docmentis-udoc-viewer/issues"
    },
    "keywords": [
        "viewer",
        "pdf",
        "pdf-viewer",
        "docx",
        "docx-viewer",
        "pptx",
        "pptx-viewer",
        "svg",
        "svg-viewer",
        "image",
        "image-viewer",
        "document",
        "document-viewer",
        "office",
        "office-viewer",
        "word",
        "powerpoint",
        "wasm",
        "webassembly"
    ],
    "main": "dist/src/index.js",
    "types": "dist/src/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/src/index.d.ts",
            "import": "./dist/src/index.js"
        },
        "./worker": {
            "types": "./dist/src/worker.d.ts",
            "import": "./dist/src/worker.js"
        }
    },
    "files": [
        "dist"
    ],
    "sideEffects": false,
    "engines": {
        "node": ">=18"
    },
    "scripts": {
        "build": "node scripts/build-styles.js && tsc && rm -rf dist/src/wasm && cp -r src/wasm dist/src/wasm && node scripts/bundle-worker.js",
        "clean": "rm -rf dist",
        "dev": "tsc --watch",
        "test": "vitest run",
        "test:watch": "vitest",
        "prepublishOnly": "npm run build"
    },
    "devDependencies": {
        "esbuild": "^0.25.0",
        "typescript": "^5.7.2",
        "vitest": "^4.0.18"
    }
}
